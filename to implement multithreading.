class MultithreadingDemo extends Thread {


public void run() {
    try {
        int a = 10 / 0;
    } catch (Exception e) {
        System.out.println("Exception is caught");
    }
}


}

public class JavaApplication10 {
public static void main(String[] args) {


    int n = 8;

    for (int i = 0; i < n; i++) {
        MultithreadingDemo obj = new MultithreadingDemo();
        obj.start();
    }
}


}
